# Local development (auth disabled by default)
SCHEMAS_DIR=./schemas
REPO_PATH=.
AUTH_ENABLED=false

# Enable auth for local OAuth testing
# AUTH_ENABLED=true
# JWT_SECRET=your-dev-secret
# FRONTEND_URL=http://localhost:5173
# OAUTH_REDIRECT_BASE=http://localhost:8000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# ADMIN_EMAILS=you@example.com
#
# Organization scoping
# Admins see only users in their own org (determined by email domain on first login).
# Users without a matching-domain admin are placed in DEFAULT_ORG_ID.
# DEFAULT_ORG_ID=default
