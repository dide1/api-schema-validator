# Copy to samconfig.toml and adjust, or use `sam deploy --guided` once.

version = 0.1

[default.deploy.parameters]
stack_name = "api-schema-validator"
resolve_s3 = true
s3_prefix = "api-schema-validator"
region = "us-east-1"
confirm_changeset = true
capabilities = "CAPABILITY_IAM"
image_repositories = []
parameter_overrides = "FrontendUrl=https://your-frontend-url JwtSecret=your-jwt-secret DatabaseUrl=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres?sslmode=require AdminEmails=you@example.com GoogleClientId= GoogleClientSecret= GitHubClientId= GitHubClientSecret= AnthropicApiKey=your-anthropic-api-key"

[default.global.parameters]
region = "us-east-1"
